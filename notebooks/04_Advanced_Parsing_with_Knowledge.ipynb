## Step 2: Setup

#%%
import os
import sys
from pathlib import Path

import pandas as pd

# Resolve repository root both for local runs and Google Colab.
PROJECT_ROOT = None
for candidate in [Path.cwd(), *Path.cwd().parents, Path('/content/esmt-workshop')]:
    if (candidate / 'src' / 'esmt_workshop').exists():
        PROJECT_ROOT = candidate
        break

if PROJECT_ROOT is None:
    raise FileNotFoundError(
        'Project root not found. Run this notebook from the ESMT_Workshop repository.'
    )

# Make local package importable inside notebook execution context.
SRC_DIR = PROJECT_ROOT / 'src'
if str(SRC_DIR) not in sys.path:
    sys.path.insert(0, str(SRC_DIR))

from esmt_workshop.evaluation import evaluate_predictions
from esmt_workshop.student_api import process_batch_addresses

print('PROJECT_ROOT =', PROJECT_ROOT)

from google.colab import auth
auth.authenticate_user()
gcloud_email = !gcloud config get-value account
STUDENT_EMAIL = gcloud_email[0] if gcloud_email else ""
os.environ['WORKSHOP_EMAIL'] = STUDENT_EMAIL
print(f"✅ Authenticated as: {STUDENT_EMAIL or 'Unknown'}")

#%% md
## Step 3: Configuration

#%%
# This is our final, most advanced pipeline configuration.
STAGE_NAME = 'two_stage'
MODEL_NAME = 'gemini-2.5-pro'
COUNTRY_MODEL = 'gemini-2.5-flash'
USE_GUARDRAILS = True
TEMPERATURE = 0.0

#%% md
## Step 4: Prompt Cell

#%%
# This prompt is designed for our two-stage system.
# It includes placeholders for the detected {country} and the {kb_text} (knowledge base).
PROMPT_TEMPLATE = '''You are an AML address parser.

Detected country:
{country}

Country format guidance:
{kb_text}

Input address:
{address}

Return strict JSON only with schema:
{schema}

Rules:
- Use country guidance only for mapping decisions.
- Do not invent missing tokens.
- Country Code must be ISO alpha-2 uppercase.
- Use empty strings when unknown.
'''

#%% md
## Step 5: Execute Pipeline on Limited Dataset

#%%
dev_df = pd.read_csv(PROJECT_ROOT / 'data/workshop/dev_labeled.csv', dtype=str).fillna('')
dev_sample = dev_df.head(20).copy()

print("--- Running advanced pipeline on a small sample ---")
pred_sample, report_sample = process_batch_addresses(
    dev_sample,
    email=STUDENT_EMAIL,
    stage=STAGE_NAME,
    model=MODEL_NAME,
    country_model=COUNTRY_MODEL,
    temperature=TEMPERATURE,
    use_guardrails=USE_GUARDRAILS,
    custom_prompt_template=PROMPT_TEMPLATE,
    kb_csv_path=str(PROJECT_ROOT / 'data/input/address_formats.csv'),
), evaluate_predictions(pred_sample, dev_sample)

#%% md
## Step 6: Analyze the Limited Run

#%%
print(report_sample['summary'])
display(report_sample['mismatches'].head(10))

#%% md
## Step 7: Execute Pipeline on Complete (Unlabeled) Test Dataset

This is the final run. We will use our best pipeline on the `test_unlabeled.csv` file to generate our submission.

#%%
test_unlabeled_df = pd.read_csv(PROJECT_ROOT / 'data/workshop/test_unlabeled.csv', dtype=str).fillna('')

print("--- Running final pipeline on the test set ---")
final_pred_df, _ = process_batch_addresses(
    test_unlabeled_df,
    email=STUDENT_EMAIL,
    stage=STAGE_NAME,
    model=MODEL_NAME,
    country_model=COUNTRY_MODEL,
    temperature=TEMPERATURE,
    use_guardrails=USE_GUARDRAILS,
    custom_prompt_template=PROMPT_TEMPLATE,
    kb_csv_path=str(PROJECT_ROOT / 'data/input/address_formats.csv'),
)

print("Final predictions generated.")
display(final_pred_df.head())

#%% md
## Step 8: Analyze the Final Run (Validation)

This step will score your predictions against the secret "answer key" (`test_labeled.csv`) to get your final score.

#%%
test_labeled_df = pd.read_csv(PROJECT_ROOT / 'data/workshop/test_labeled.csv', dtype=str).fillna('')
final_report = evaluate_predictions(final_pred_df, test_labeled_df)

print("--- Final Test Set Score ---")
print(final_report['summary'])
display(final_report['field_metrics'])

#%% md
## Step 9: Publish to Leaderboard

#%%
PUBLISH_TO_LEADERBOARD = False # Set to True to publish your final score

if PUBLISH_TO_LEADERBOARD:
    final_accuracy = final_report['summary'].get('micro_accuracy', 0.0)
    print(f"Publishing final score of {final_accuracy:.4f} to the leaderboard...")
    # In a real scenario, this would be a function to post the score.
    print("Leaderboard updated. Congratulations!")
