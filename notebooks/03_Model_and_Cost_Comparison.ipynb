## Step 2: Setup

#%%
import os
import sys
from pathlib import Path

import pandas as pd

# Resolve repository root both for local runs and Google Colab.
PROJECT_ROOT = None
for candidate in [Path.cwd(), *Path.cwd().parents, Path('/content/esmt-workshop')]:
    if (candidate / 'src' / 'esmt_workshop').exists():
        PROJECT_ROOT = candidate
        break

if PROJECT_ROOT is None:
    raise FileNotFoundError(
        'Project root not found. Run this notebook from the ESMT_Workshop repository.'
    )

# Make local package importable inside notebook execution context.
SRC_DIR = PROJECT_ROOT / 'src'
if str(SRC_DIR) not in sys.path:
    sys.path.insert(0, str(SRC_DIR))

from esmt_workshop.evaluation import evaluate_predictions
from esmt_workshop.student_api import process_batch_addresses

print('PROJECT_ROOT =', PROJECT_ROOT)

from google.colab import auth
auth.authenticate_user()
gcloud_email = !gcloud config get-value account
STUDENT_EMAIL = gcloud_email[0] if gcloud_email else ""
os.environ['WORKSHOP_EMAIL'] = STUDENT_EMAIL
print(f"✅ Authenticated as: {STUDENT_EMAIL or 'Unknown'}")

#%% md
## Step 3: Prompt Cell

#%%
# Paste your best-performing prompt from the previous notebook here.
PROMPT_TEMPLATE = '''You are an AML address parser.

Input address:
{address}

Return strict JSON only with schema:
{schema}

Rules:
- Extract Town Name, Postal Code, Remaining Address, Country Code (2 characters).
- Country Code must be ISO alpha-2 uppercase.
- Do not invent values.
- Use empty strings if unknown.
'''

#%% md
## Step 4: Execute Pipeline on Limited Dataset

We will run the same prompt on a small sample of data, first with the fast model, then with the advanced model.

#%%
dev_df = pd.read_csv(PROJECT_ROOT / 'data/workshop/dev_labeled.csv', dtype=str).fillna('')
dev_sample = dev_df.head(20).copy()

#%%
print("--- Running on Fast Model (gemini-2.5-flash) ---")
pred_flash, report_flash = process_batch_addresses(
    dev_sample,
    email=STUDENT_EMAIL,
    stage='advanced',
    model='gemini-2.5-flash',
    temperature=0.0,
    custom_prompt_template=PROMPT_TEMPLATE,
), evaluate_predictions(pred_flash, dev_sample)

#%%
print("\n--- Running on Advanced Model (gemini-2.5-pro) ---")
pred_pro, report_pro = process_batch_addresses(
    dev_sample,
    email=STUDENT_EMAIL,
    stage='advanced',
    model='gemini-2.5-pro',
    temperature=0.0,
    custom_prompt_template=PROMPT_TEMPLATE,
), evaluate_predictions(pred_pro, dev_sample)

#%% md
## Step 5: Analyze the Results

#%%
accuracy_flash = report_flash['summary'].get('micro_accuracy', 0.0)
accuracy_pro = report_pro['summary'].get('micro_accuracy', 0.0)

print(f"Flash Model Accuracy: {accuracy_flash:.4f}")
print(f"Pro Model Accuracy:   {accuracy_pro:.4f}")
print(f"Accuracy Improvement: {accuracy_pro - accuracy_flash:+.4f}")

#%% md
### Cost vs. Quality Discussion

While the `gemini-2.5-pro` model likely gives higher accuracy, it is also more expensive to run.

*   **Question for discussion:** Is the accuracy improvement worth the extra cost?
*   In what scenarios would you choose the cheaper model?
*   In what scenarios would you choose the more expensive model?

This trade-off is a critical business decision when building AI products.

#%% md
## Step 6: Execute Pipeline on Complete Dataset

#%%
RUN_ON_FULL_DATASET = False # Set to True to run on the full development set

if RUN_ON_FULL_DATASET:
    print("Running on the full development dataset with the Pro model...")
    pred_full, report_full = process_batch_addresses(
        dev_df,
        email=STUDENT_EMAIL,
        stage='advanced',
        model='gemini-2.5-pro',
        temperature=0.0,
        custom_prompt_template=PROMPT_TEMPLATE,
    ), evaluate_predictions(pred_full, dev_df)
    print("Analysis of the full run:")
    print(report_full['summary'])

